GOVPRESS_API_KEY=change-me
GOVPRESS_CORS_ALLOW_ORIGINS=https://wavelen-jw.github.io

# 업로드 제한 — 저성능 서버 권장값
GOVPRESS_MAX_UPLOAD_BYTES=10000000
GOVPRESS_UPLOAD_RATE_LIMIT_COUNT=6
GOVPRESS_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60

# 작업 보관 기간 — 저성능 서버 권장값 (디스크 절약)
GOVPRESS_JOB_TTL_HOURS=24

# 변환 타임아웃 (초). 300초 = 5분. 무한 대기 방지
GOVPRESS_CONVERSION_TIMEOUT_SECONDS=300

GOVPRESS_TURNSTILE_SECRET_KEY=
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-token
GOVPRESS_CONVERTER_SPEC=
GOVPRESS_CONVERTER_MIN_VERSION=
GOVPRESS_CONVERTER_EXTRA_INDEX_URL=
GOVPRESS_CONVERTER_ALLOW_LOCAL_FALLBACK=1

# Telegram 알림 (선택) - 대기 3개 이상 또는 5분 이상 대기 시 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
